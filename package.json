{
  "name": "owenloop",
  "version": "0.2.0",
  "description": "Deterministic rails for agentic workflows. Declare steps and dependencies; the engine guarantees order, redoes what changes invalidate, and stops what keeps failing — instead of hoping the agent follows through.",
  "license": "Apache-2.0",
  "author": "typicalday",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/typicalday/owenloop.git"
  },
  "homepage": "https://github.com/typicalday/owenloop#readme",
  "bugs": {
    "url": "https://github.com/typicalday/owenloop/issues"
  },
  "keywords": [
    "workflow",
    "dataflow",
    "engine",
    "sqlite",
    "orchestration",
    "dag",
    "state-machine",
    "ai",
    "agents",
    "llm",
    "agentic-workflows",
    "automation"
  ],
  "bin": {
    "owenloop": "bin/owenloop.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin",
    "examples/workflows",
    "docs",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "owenloop": "node bin/owenloop.mjs",
    "test": "node --test --test-reporter=spec test/*.test.ts",
    "test:quiet": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "check": "npm run typecheck && npm run build && npm run test:quiet",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
