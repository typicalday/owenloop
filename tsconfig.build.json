{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "rewriteRelativeImportExtensions": true,
    "stripInternal": true
  },
  "include": ["src/**/*.ts"]
}
